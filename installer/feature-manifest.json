{
  "schemaVersion": 1,
  "product": "Mix Studio",
  "target": "windows-nvidia",
  "notes": "The bootstrapper uses this selection to install only the required model families and writes the same keys to data/settings.json. Model source URLs and license acknowledgements are resolved separately by the installer.",
  "features": [
    {
      "id": "core.image",
      "label": "Image generation",
      "required": true,
      "models": ["krea2-turbo", "krea2-raw", "krea2-turbo-lora", "qwen3-vl", "qwen-image-vae"],
      "nodes": ["core", "TextGenerate"]
    },
    {
      "id": "edit.klein4",
      "label": "Klein 4B Edit",
      "default": true,
      "models": ["flux-2-klein-4b", "qwen-3-4b", "flux2-vae"],
      "nodes": ["Flux2Scheduler", "ReferenceLatent"]
    },
    {
      "id": "edit.klein9",
      "label": "Klein 9B Edit",
      "default": true,
      "models": ["flux-2-klein-9b", "qwen-3-8b", "flux2-vae", "sam3"],
      "nodes": ["Flux2Scheduler", "ReferenceLatent", "ComfyUI-SAM3"]
    },
    {
      "id": "edit.qwen",
      "label": "Qwen Edit + multi-angle",
      "default": true,
      "models": ["qwen-image-edit-2511", "qwen-image-edit-lightning", "qwen-image-edit-multi-angle", "sam3"],
      "nodes": ["TextEncodeQwenImageEditPlus", "FluxKontextMultiReferenceLatentMethod", "ComfyUI-SAM3"]
    },
    {
      "id": "edit.krea2",
      "label": "Krea 2 Inpaint + Regions",
      "default": true,
      "models": ["krea2", "sam3"],
      "nodes": ["Krea2RegionalMultiLoRAV3", "Ideogram4PromptBuilderKJ", "ComfyUI-SAM3"]
    },
    {
      "id": "edit.krea2ref",
      "label": "Krea 2 Edit",
      "default": true,
      "models": ["krea2"],
      "nodes": ["Krea2EditRebalance"]
    },
    {
      "id": "video.ltx",
      "label": "LTX 2.3 Video",
      "default": true,
      "models": ["ltx-2.3", "ltx-distilled", "gemma-3", "ltx-spatial-upscaler"],
      "nodes": ["VideoHelperSuite", "LTXV"]
    },
    {
      "id": "video.ltxEdit",
      "label": "LTX Edit Anything",
      "default": true,
      "dependsOn": ["video.ltx"],
      "models": ["ltx-edit-anything"],
      "nodes": ["VideoHelperSuite", "LTXVAddGuide"]
    },
    {
      "id": "video.eros",
      "label": "10Eros DMD",
      "default": true,
      "models": ["10eros", "ltx-dmd", "gemma-3"],
      "nodes": ["EchoDMDSampler", "KJNodes"]
    },
    {
      "id": "video.wan",
      "label": "Wan 2.2 Video",
      "default": true,
      "models": ["wan2.2-high", "wan2.2-low", "umt5-xxl", "wan-vae", "wan-lightx2v"],
      "nodes": ["WanImageToVideo", "VideoHelperSuite"]
    },
    {
      "id": "video.scail",
      "label": "SCAIL 2 Motion Transfer",
      "default": true,
      "dependsOn": ["video.wan"],
      "models": ["scail2", "sam3.1", "clip-vision-h", "pusa"],
      "nodes": ["WanSCAILToVideo", "SAM3_VideoTrack", "comfyui-scail2-infinity"]
    }
  ]
}
